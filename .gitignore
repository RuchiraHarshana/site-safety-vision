# =========================
# DATA (ignore contents, keep structure only)
# =========================

data/*
!data/.gitkeep
!data/samples/
data/samples/*
!data/samples/.gitkeep


# =========================
# OUTPUTS (ignore contents, keep structure only)
# =========================

outputs/*
!outputs/.gitkeep
!outputs/predictions/
outputs/predictions/*
!outputs/predictions/.gitkeep

# Ignore generated artifacts
outputs/**/*.mp4
outputs/**/*.avi
outputs/**/*.mov
outputs/**/*.mkv
outputs/**/*.json


# =========================
# MODELS (track .pt files)
# =========================

# Model weights are intentionally tracked


# =========================
# PYTHON CACHE
# =========================

__pycache__/
*.py[cod]
*$py.class
src/**/__pycache__/


